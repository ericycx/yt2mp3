{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "nodejs": "*"
  },
  "steps": {
    "build": {
      "commands": [
        "apt-get update && apt-get install -y --no-install-recommends ffmpeg nodejs npm"
      ]
    }
  },
  "deploy": {
    "startCommand": "python3 yt2mp3.py"
  }
}
